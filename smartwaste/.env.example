# Smart Waste Monitoring System - Environment Variables
# Copy this file to .env and fill in your actual values

# Flask Security
SECRET_KEY=your-secret-key-here-make-it-long-and-random

# Email Configuration (for alerts)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_TO=municipal@city.gov

# User Credentials (change these!)
ADMIN_PASSWORD=your-secure-admin-password
OFFICER_PASSWORD=your-secure-officer-password

# Optional: Database URL (defaults to SQLite)
# DATABASE_URL=sqlite:///waste_monitoring.db

# Optional: Port (defaults to 10000)
# PORT=10000